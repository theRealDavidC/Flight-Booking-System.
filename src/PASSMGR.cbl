IDENTIFICATION DIVISION.
PROGRAM-ID. PASSMGR.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT PASS-FILE ASSIGN TO 'data/PASSENGERS.dat'
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS PAX-ID
        ALTERNATE RECORD KEY IS PAX-PASSPORT
        FILE STATUS IS WS-FS-PASS.

    SELECT OPTIONAL PAXSEQ-FILE ASSIGN TO 'data/PAXSEQ.dat'
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-FS-SEQ.

DATA DIVISION.
FILE SECTION.
FD  PASS-FILE.
COPY 'PASSENGER-REC.cpy'.

FD  PAXSEQ-FILE.
01  PAXSEQ-REC     PIC 9(6).

WORKING-STORAGE SECTION.
01 WS-FS-PASS       PIC XX VALUE SPACES.
01 WS-FS-SEQ        PIC XX VALUE SPACES.
01 WS-CHOICE        PIC X  VALUE SPACE.
01 WS-RUNNING       PIC X  VALUE 'Y'.
01 WS-EOT           PIC X  VALUE 'N'.
01 WS-NEXT-ID       PIC 9(6) VALUE 0.
01 WS-NEXT-ID-DISP  PIC 9(6).
01 WS-SEARCH        PIC X(12) VALUE SPACES.

PROCEDURE DIVISION.
0000-MAIN.
    OPEN I-O PASS-FILE
    IF WS-FS-PASS = '35'
        OPEN OUTPUT PASS-FILE
        CLOSE PASS-FILE
        OPEN I-O PASS-FILE
    END-IF
    PERFORM UNTIL WS-RUNNING = 'N'
        PERFORM 1000-MENU
        ACCEPT WS-CHOICE
        EVALUATE WS-CHOICE
            WHEN '1' PERFORM 2000-REGISTER
            WHEN '2' PERFORM 3000-FIND-BY-PASSPORT
            WHEN '3' PERFORM 4000-LIST-ALL
            WHEN '4' MOVE 'N' TO WS-RUNNING
            WHEN OTHER
                DISPLAY '  Invalid option.'
        END-EVALUATE
    END-PERFORM
    CLOSE PASS-FILE
    MOVE 'Y' TO WS-RUNNING
    GOBACK.

1000-MENU.
    DISPLAY ' '
    DISPLAY '--- PASSENGER MANAGEMENT ---'
    DISPLAY '  1. Register Passenger'
    DISPLAY '  2. Find by Passport'
    DISPLAY '  3. List All Passengers'
    DISPLAY '  4. Back'
    DISPLAY 'Select: ' WITH NO ADVANCING.

2000-REGISTER.
    PERFORM 8000-NEXT-PAX-ID
    DISPLAY ' '
    DISPLAY '--- REGISTER PASSENGER ---'
    DISPLAY 'First Name     : ' WITH NO ADVANCING
    ACCEPT PAX-FIRST-NAME
    DISPLAY 'Last Name      : ' WITH NO ADVANCING
    ACCEPT PAX-LAST-NAME
    DISPLAY 'Passport Number: ' WITH NO ADVANCING
    ACCEPT PAX-PASSPORT
    DISPLAY 'Email          : ' WITH NO ADVANCING
    ACCEPT PAX-EMAIL
    DISPLAY 'Phone          : ' WITH NO ADVANCING
    ACCEPT PAX-PHONE
    WRITE PASSENGER-RECORD
        INVALID KEY
            DISPLAY '  ERROR: Passport number already registered.'
        NOT INVALID KEY
            DISPLAY '  Passenger registered. ID: ' PAX-ID
    END-WRITE.

3000-FIND-BY-PASSPORT.
    DISPLAY ' '
    DISPLAY 'Passport Number: ' WITH NO ADVANCING
    ACCEPT WS-SEARCH
    MOVE WS-SEARCH TO PAX-PASSPORT
    READ PASS-FILE KEY IS PAX-PASSPORT
        INVALID KEY
            DISPLAY '  Passenger not found.'
        NOT INVALID KEY
            PERFORM 5000-SHOW-PASSENGER
    END-READ.

4000-LIST-ALL.
    DISPLAY ' '
    DISPLAY '--- ALL PASSENGERS ---'
    DISPLAY 'ID         FIRST NAME           LAST NAME            PASSPORT'
    DISPLAY '---------- -------------------- -------------------- ----------'
    MOVE LOW-VALUES TO PAX-ID
    START PASS-FILE KEY >= PAX-ID
        INVALID KEY
            DISPLAY '  No passengers found.'
            EXIT PARAGRAPH
    END-START
    MOVE 'N' TO WS-EOT
    PERFORM UNTIL WS-EOT = 'Y'
        READ PASS-FILE NEXT RECORD
            AT END MOVE 'Y' TO WS-EOT
        END-READ
        IF WS-EOT = 'N'
            DISPLAY PAX-ID ' ' PAX-FIRST-NAME
                ' ' PAX-LAST-NAME ' ' PAX-PASSPORT
        END-IF
    END-PERFORM.

5000-SHOW-PASSENGER.
    DISPLAY ' '
    DISPLAY '  Passenger ID: ' PAX-ID
    DISPLAY '  Name        : ' PAX-FIRST-NAME ' ' PAX-LAST-NAME
    DISPLAY '  Passport    : ' PAX-PASSPORT
    DISPLAY '  Email       : ' PAX-EMAIL
    DISPLAY '  Phone       : ' PAX-PHONE.

8000-NEXT-PAX-ID.
    OPEN INPUT PAXSEQ-FILE
    MOVE 0 TO WS-NEXT-ID
    READ PAXSEQ-FILE INTO WS-NEXT-ID
        AT END CONTINUE
    END-READ
    CLOSE PAXSEQ-FILE
    ADD 1 TO WS-NEXT-ID
    OPEN OUTPUT PAXSEQ-FILE
    WRITE PAXSEQ-REC FROM WS-NEXT-ID
    CLOSE PAXSEQ-FILE
    MOVE WS-NEXT-ID TO WS-NEXT-ID-DISP
    STRING 'PA' WS-NEXT-ID-DISP DELIMITED SIZE INTO PAX-ID.
