IDENTIFICATION DIVISION.
PROGRAM-ID. BOOKMGR.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT BOOKING-FILE ASSIGN TO 'data/BOOKINGS.dat'
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS BKG-REF
        ALTERNATE RECORD KEY IS BKG-PAX-ID WITH DUPLICATES
        FILE STATUS IS WS-FS-BKG.

    SELECT FLIGHT-FILE ASSIGN TO 'data/FLIGHTS.dat'
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS FLT-ID
        ALTERNATE RECORD KEY IS FLT-NUMBER WITH DUPLICATES
        FILE STATUS IS WS-FS-FLT.

    SELECT PASS-FILE ASSIGN TO 'data/PASSENGERS.dat'
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS PAX-ID
        ALTERNATE RECORD KEY IS PAX-PASSPORT
        FILE STATUS IS WS-FS-PAX.

    SELECT OPTIONAL BKGSEQ-FILE ASSIGN TO 'data/BKGSEQ.dat'
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-FS-SEQ.

DATA DIVISION.
FILE SECTION.
FD  BOOKING-FILE.
COPY 'BOOKING-REC.cpy'.

FD  FLIGHT-FILE.
COPY 'FLIGHT-REC.cpy'.

FD  PASS-FILE.
COPY 'PASSENGER-REC.cpy'.

FD  BKGSEQ-FILE.
01  BKGSEQ-REC     PIC 9(6).

WORKING-STORAGE SECTION.
01 WS-FS-BKG        PIC XX VALUE SPACES.
01 WS-FS-FLT        PIC XX VALUE SPACES.
01 WS-FS-PAX        PIC XX VALUE SPACES.
01 WS-FS-SEQ        PIC XX VALUE SPACES.
01 WS-CHOICE        PIC X  VALUE SPACE.
01 WS-RUNNING       PIC X  VALUE 'Y'.
01 WS-EOT           PIC X  VALUE 'N'.
01 WS-CONFIRM       PIC X  VALUE 'N'.
01 WS-NEXT-ID       PIC 9(6) VALUE 0.
01 WS-NEXT-ID-DISP  PIC 9(6).
01 WS-SEARCH-REF    PIC X(8)  VALUE SPACES.
01 WS-SEARCH-PAX    PIC X(8)  VALUE SPACES.
01 WS-SEARCH-FLT    PIC X(6)  VALUE SPACES.
01 WS-CLASS-IN      PIC X     VALUE SPACE.
01 WS-AMOUNT-DISP   PIC ZZZ,ZZ9.99.
01 WS-PRICE-DISP    PIC ZZZ,ZZ9.99.
01 WS-SEAT-NUM      PIC 9(3).
01 WS-SEAT-STR      PIC 9(3).
01 WS-SAVED-FLT-ID  PIC X(6).

PROCEDURE DIVISION.
0000-MAIN.
    PERFORM 9000-OPEN-FILES
    PERFORM UNTIL WS-RUNNING = 'N'
        PERFORM 1000-MENU
        ACCEPT WS-CHOICE
        EVALUATE WS-CHOICE
            WHEN '1' PERFORM 2000-CREATE-BOOKING
            WHEN '2' PERFORM 3000-CANCEL-BOOKING
            WHEN '3' PERFORM 4000-VIEW-BOOKING
            WHEN '4' PERFORM 5000-LIST-BY-PASSENGER
            WHEN '5' MOVE 'N' TO WS-RUNNING
            WHEN OTHER
                DISPLAY '  Invalid option.'
        END-EVALUATE
    END-PERFORM
    PERFORM 9100-CLOSE-FILES
    MOVE 'Y' TO WS-RUNNING
    GOBACK.

1000-MENU.
    DISPLAY ' '
    DISPLAY '--- BOOKING MANAGEMENT ---'
    DISPLAY '  1. Create Booking'
    DISPLAY '  2. Cancel Booking'
    DISPLAY '  3. View Booking'
    DISPLAY '  4. List Bookings by Passenger'
    DISPLAY '  5. Back'
    DISPLAY 'Select: ' WITH NO ADVANCING.

2000-CREATE-BOOKING.
    DISPLAY ' '
    DISPLAY '--- CREATE BOOKING ---'
    DISPLAY 'Passenger ID: ' WITH NO ADVANCING
    ACCEPT WS-SEARCH-PAX
    MOVE WS-SEARCH-PAX TO PAX-ID
    READ PASS-FILE KEY IS PAX-ID
        INVALID KEY
            DISPLAY '  Passenger not found.'
            EXIT PARAGRAPH
    END-READ
    DISPLAY 'Passenger: ' PAX-FIRST-NAME ' ' PAX-LAST-NAME
    DISPLAY 'Flight ID : ' WITH NO ADVANCING
    ACCEPT WS-SEARCH-FLT
    MOVE WS-SEARCH-FLT TO FLT-ID
    READ FLIGHT-FILE KEY IS FLT-ID
        INVALID KEY
            DISPLAY '  Flight not found.'
            EXIT PARAGRAPH
    END-READ
    IF FLT-STATUS NOT = 'A'
        DISPLAY '  Flight is not active.'
        EXIT PARAGRAPH
    END-IF
    IF FLT-AVAIL-SEATS = 0
        DISPLAY '  No seats available on this flight.'
        EXIT PARAGRAPH
    END-IF
    MOVE FLT-PRICE TO WS-PRICE-DISP
    DISPLAY 'Flight : ' FLT-NUMBER ' ' FLT-ORIGIN
        ' -> ' FLT-DESTINATION
    DISPLAY 'Date   : ' FLT-DEP-DATE
        '  Dep: ' FLT-DEP-TIME '  Arr: ' FLT-ARR-TIME
    DISPLAY 'Price  : ' WS-PRICE-DISP
    DISPLAY 'Class (E=Economy, B=Business, F=First): '
        WITH NO ADVANCING
    ACCEPT WS-CLASS-IN
    IF WS-CLASS-IN NOT = 'E' AND WS-CLASS-IN NOT = 'B'
                               AND WS-CLASS-IN NOT = 'F'
        DISPLAY '  Invalid class. Use E, B or F.'
        EXIT PARAGRAPH
    END-IF
    DISPLAY 'Confirm booking? (Y/N): ' WITH NO ADVANCING
    ACCEPT WS-CONFIRM
    IF WS-CONFIRM NOT = 'Y'
        DISPLAY '  Booking aborted.'
        EXIT PARAGRAPH
    END-IF
    PERFORM 8000-NEXT-BKG-ID
    COMPUTE WS-SEAT-NUM = FLT-TOTAL-SEATS - FLT-AVAIL-SEATS + 1
    MOVE WS-SEAT-NUM TO WS-SEAT-STR
    STRING WS-CLASS-IN WS-SEAT-STR DELIMITED SIZE INTO BKG-SEAT
    MOVE WS-SEARCH-FLT   TO BKG-FLIGHT-ID
    MOVE WS-SEARCH-PAX   TO BKG-PAX-ID
    MOVE FUNCTION CURRENT-DATE(1:8) TO BKG-DATE
    MOVE 'C'             TO BKG-STATUS
    MOVE WS-CLASS-IN     TO BKG-CLASS
    MOVE FLT-PRICE       TO BKG-AMOUNT
    WRITE BOOKING-RECORD
        INVALID KEY
            DISPLAY '  ERROR: Booking reference conflict, retry.'
            EXIT PARAGRAPH
    END-WRITE
    SUBTRACT 1 FROM FLT-AVAIL-SEATS
    REWRITE FLIGHT-RECORD
        INVALID KEY
            DISPLAY '  WARNING: Seat count not updated.'
    END-REWRITE
    DISPLAY ' '
    DISPLAY '  Booking confirmed!'
    DISPLAY '  Reference : ' BKG-REF
    DISPLAY '  Seat      : ' BKG-SEAT
    DISPLAY '  Amount    : ' WS-PRICE-DISP.

3000-CANCEL-BOOKING.
    DISPLAY ' '
    DISPLAY 'Booking Reference: ' WITH NO ADVANCING
    ACCEPT WS-SEARCH-REF
    MOVE WS-SEARCH-REF TO BKG-REF
    READ BOOKING-FILE KEY IS BKG-REF
        INVALID KEY
            DISPLAY '  Booking not found.'
            EXIT PARAGRAPH
    END-READ
    IF BKG-STATUS = 'X'
        DISPLAY '  Booking is already cancelled.'
        EXIT PARAGRAPH
    END-IF
    DISPLAY 'Cancel booking ' BKG-REF '? (Y/N): '
        WITH NO ADVANCING
    ACCEPT WS-CONFIRM
    IF WS-CONFIRM NOT = 'Y'
        EXIT PARAGRAPH
    END-IF
    MOVE BKG-FLIGHT-ID TO WS-SAVED-FLT-ID
    MOVE 'X' TO BKG-STATUS
    REWRITE BOOKING-RECORD
        INVALID KEY
            DISPLAY '  ERROR: Could not cancel booking.'
            EXIT PARAGRAPH
    END-REWRITE
    MOVE WS-SAVED-FLT-ID TO FLT-ID
    READ FLIGHT-FILE KEY IS FLT-ID
        NOT INVALID KEY
            ADD 1 TO FLT-AVAIL-SEATS
            REWRITE FLIGHT-RECORD
    END-READ
    DISPLAY '  Booking ' BKG-REF ' cancelled successfully.'.

4000-VIEW-BOOKING.
    DISPLAY ' '
    DISPLAY 'Booking Reference: ' WITH NO ADVANCING
    ACCEPT WS-SEARCH-REF
    MOVE WS-SEARCH-REF TO BKG-REF
    READ BOOKING-FILE KEY IS BKG-REF
        INVALID KEY
            DISPLAY '  Booking not found.'
        NOT INVALID KEY
            PERFORM 6000-SHOW-BOOKING
    END-READ.

5000-LIST-BY-PASSENGER.
    DISPLAY ' '
    DISPLAY 'Passenger ID: ' WITH NO ADVANCING
    ACCEPT WS-SEARCH-PAX
    DISPLAY ' '
    DISPLAY '--- BOOKINGS FOR PASSENGER ' WS-SEARCH-PAX ' ---'
    DISPLAY 'REFERENCE FLIGHT STATUS SEAT DATE     CL       AMOUNT'
    DISPLAY '--------- ------ ------ ---- -------- -- ----------'
    MOVE WS-SEARCH-PAX TO BKG-PAX-ID
    START BOOKING-FILE KEY = BKG-PAX-ID
        INVALID KEY
            DISPLAY '  No bookings found.'
            EXIT PARAGRAPH
    END-START
    MOVE 'N' TO WS-EOT
    PERFORM UNTIL WS-EOT = 'Y'
        READ BOOKING-FILE NEXT RECORD
            AT END MOVE 'Y' TO WS-EOT
        END-READ
        IF WS-EOT = 'N'
            IF BKG-PAX-ID = WS-SEARCH-PAX
                MOVE BKG-AMOUNT TO WS-AMOUNT-DISP
                DISPLAY BKG-REF ' ' BKG-FLIGHT-ID
                    '  ' BKG-STATUS '    ' BKG-SEAT
                    ' ' BKG-DATE ' ' BKG-CLASS
                    '  ' WS-AMOUNT-DISP
            ELSE
                MOVE 'Y' TO WS-EOT
            END-IF
        END-IF
    END-PERFORM.

6000-SHOW-BOOKING.
    MOVE BKG-AMOUNT TO WS-AMOUNT-DISP
    DISPLAY ' '
    DISPLAY '  Reference : ' BKG-REF
    DISPLAY '  Flight    : ' BKG-FLIGHT-ID
    DISPLAY '  Passenger : ' BKG-PAX-ID
    DISPLAY '  Seat      : ' BKG-SEAT
    DISPLAY '  Class     : ' BKG-CLASS
    DISPLAY '  Date      : ' BKG-DATE
    DISPLAY '  Amount    : ' WS-AMOUNT-DISP
    DISPLAY '  Status    : ' BKG-STATUS.

8000-NEXT-BKG-ID.
    OPEN INPUT BKGSEQ-FILE
    MOVE 0 TO WS-NEXT-ID
    READ BKGSEQ-FILE INTO WS-NEXT-ID
        AT END CONTINUE
    END-READ
    CLOSE BKGSEQ-FILE
    ADD 1 TO WS-NEXT-ID
    OPEN OUTPUT BKGSEQ-FILE
    WRITE BKGSEQ-REC FROM WS-NEXT-ID
    CLOSE BKGSEQ-FILE
    MOVE WS-NEXT-ID TO WS-NEXT-ID-DISP
    STRING 'BK' WS-NEXT-ID-DISP DELIMITED SIZE INTO BKG-REF.

9000-OPEN-FILES.
    OPEN I-O BOOKING-FILE
    IF WS-FS-BKG = '35'
        OPEN OUTPUT BOOKING-FILE
        CLOSE BOOKING-FILE
        OPEN I-O BOOKING-FILE
    END-IF
    OPEN I-O FLIGHT-FILE
    IF WS-FS-FLT = '35'
        OPEN OUTPUT FLIGHT-FILE
        CLOSE FLIGHT-FILE
        OPEN I-O FLIGHT-FILE
    END-IF
    OPEN I-O PASS-FILE
    IF WS-FS-PAX = '35'
        OPEN OUTPUT PASS-FILE
        CLOSE PASS-FILE
        OPEN I-O PASS-FILE
    END-IF.

9100-CLOSE-FILES.
    CLOSE BOOKING-FILE
    CLOSE FLIGHT-FILE
    CLOSE PASS-FILE.
